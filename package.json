{
  "name": "slopmop",
  "version": "1.0.0",
  "description": "Browser-based Claude CLI terminal with file explorer, voice I/O, and GSD integration",
  "type": "module",
  "scripts": {
    "setup": "bash scripts/setup.sh",
    "update-vendor": "bash scripts/update-vendor.sh",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "PORT=3000 tsx watch server/index.ts",
    "client": "vite",
    "build": "tsc && vite build",
    "test": "vitest run",
    "postinstall": "chmod +x node_modules/node-pty/prebuilds/darwin-arm64/spawn-helper 2>/dev/null || true"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "concurrently": "^9.0.0",
    "express": "^4.19.0",
    "grammy": "^1.42.0",
    "isbinaryfile": "^5.0.7",
    "mermaid": "^11.14.0",
    "node-pty": "^1.1.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "shiki": "^4.0.2",
    "ws": "^8.17.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.5.12",
    "@vitejs/plugin-react": "^4.3.0",
    "jsdom": "^24.0.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
